<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="TextAppearance.Katzen.Headline" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:fontFamily">@font/poppins_bold</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>

    <style name="TextAppearance.Katzen.Subtitle" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:fontFamily">@font/poppins_regular</item>
        <item name="android:textColor">?attr/colorOnSurfaceVariant</item>
    </style>

    <style name="TextAppearance.Katzen.ListTitle" parent="TextAppearance.Material3.TitleSmall">
        <item name="android:fontFamily">@font/poppins_regular</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.Katzen.ListSubtitle" parent="TextAppearance.Material3.BodySmall">
        <item name="android:fontFamily">@font/poppins_light</item>
        <item name="android:textColor">?attr/colorOnSurfaceVariant</item>
    </style>

    <style name="Widget.Katzen.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">18dp</item>
        <item name="cardElevation">2dp</item>
        <item name="cardBackgroundColor">?attr/colorSurface</item>
        <item name="strokeColor">?attr/colorOutlineVariant</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Widget.Katzen.ListItemCard" parent="Widget.Katzen.Card">
        <item name="android:layout_marginHorizontal">@dimen/list_item_padding</item>
        <item name="android:layout_marginVertical">6dp</item>
    </style>

    <style name="Widget.Katzen.Button.Primary" parent="Widget.Material3.Button">
        <item name="android:textColor">?attr/colorOnPrimary</item>
        <item name="android:fontFamily">@font/poppins_bold</item>
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">@dimen/button_corner_radius</item>
        <item name="backgroundTint">?attr/colorPrimary</item>
    </style>

    <style name="Widget.Katzen.Button.Fab" parent="Widget.Material3.Button">
        <item name="android:textColor">?attr/colorOnSecondary</item>
        <item name="android:fontFamily">@font/poppins_bold</item>
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">@dimen/button_corner_radius</item>
        <item name="backgroundTint">?attr/colorSecondary</item>
        <item name="iconTint">?attr/colorOnSecondary</item>
        <item name="iconPadding">8dp</item>
    </style>

    <style name="Widget.Katzen.ExtendedFab" parent="Widget.Material3.ExtendedFloatingActionButton.Primary">
        <item name="android:textColor">?attr/colorOnSecondary</item>
        <item name="android:fontFamily">@font/poppins_bold</item>
        <item name="android:textAllCaps">false</item>
        <item name="backgroundTint">?attr/colorSecondary</item>
        <item name="iconTint">?attr/colorOnSecondary</item>
    </style>

    <style name="Widget.Katzen.TextInput" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">@dimen/input_corner_radius</item>
        <item name="boxCornerRadiusTopEnd">@dimen/input_corner_radius</item>
        <item name="boxCornerRadiusBottomStart">@dimen/input_corner_radius</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/input_corner_radius</item>
        <item name="boxStrokeColor">@color/input_stroke_color</item>
        <item name="hintTextColor">?attr/colorOnSurfaceVariant</item>
        <item name="startIconTint">?attr/colorPrimary</item>
    </style>

    <style name="Widget.Katzen.SearchInput" parent="Widget.Katzen.TextInput">
        <item name="boxBackgroundColor">?attr/colorSurface</item>
        <item name="startIconDrawable">@drawable/ic_search_m3</item>
        <item name="endIconMode">clear_text</item>
    </style>

    <style name="Widget.Katzen.Chip.Status" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textSize">11sp</item>
        <item name="android:minHeight">32dp</item>
        <item name="cornerRadius">16dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="strokeColor">?attr/colorOutline</item>
    </style>

    <style name="Widget.Katzen.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="titleTextColor">?attr/colorOnPrimary</item>
        <item name="android:background">?attr/colorPrimary</item>
        <item name="titleTextAppearance">@style/TextAppearance.Katzen.Headline</item>
    </style>

    <style name="Widget.Katzen.IconAction" parent="">
        <item name="android:layout_width">40dp</item>
        <item name="android:layout_height">40dp</item>
        <item name="android:background">@drawable/bg_icon_action</item>
        <item name="android:padding">8dp</item>
    </style>

</resources>
