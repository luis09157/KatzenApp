<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    style="@style/Widget.Katzen.ListItemCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:rippleColor="@color/ripple_light">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <View
            android:layout_width="5dp"
            android:layout_height="match_parent"
            android:background="@drawable/bg_portal_menu_accent" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvNombre"
                style="@style/TextAppearance.Katzen.ListTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                tools:text="Corte de uñas" />

            <TextView
                android:id="@+id/tvPrecio"
                style="@style/TextAppearance.Katzen.ListSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                tools:text="$80.00" />

            <TextView
                android:id="@+id/tvTipo"
                style="@style/TextAppearance.Katzen.ListSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                tools:text="Estética" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEstado"
                style="@style/Widget.Katzen.Chip.Status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Activo" />
        </LinearLayout>

        <FrameLayout
            android:id="@+id/btnEliminar"
            android:layout_width="48dp"
            android:layout_height="match_parent"
            android:background="@drawable/bg_delete_action"
            android:foreground="?attr/selectableItemBackground">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:contentDescription="@string/cliente_action_delete"
                android:src="@drawable/ic_delete_m3"
                app:tint="@color/white" />
        </FrameLayout>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
