<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingBottom="4dp">

    <View
        android:id="@+id/timeline_line"
        android:layout_width="2dp"
        android:layout_height="0dp"
        android:layout_marginStart="19dp"
        android:background="@color/portal_timeline_line"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/timeline_dot" />

    <View
        android:id="@+id/timeline_dot"
        android:layout_width="14dp"
        android:layout_height="14dp"
        android:layout_marginStart="13dp"
        android:layout_marginTop="22dp"
        android:background="@drawable/bg_portal_timeline_dot_stroke"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_notificacion"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="4dp"
        android:layout_marginBottom="12dp"
        android:clickable="true"
        android:focusable="true"
        app:cardBackgroundColor="@color/surface_card"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/timeline_dot"
        app:layout_constraintTop_toTopOf="parent"
        app:rippleColor="@color/ripple_light"
        app:strokeColor="@color/divider"
        app:strokeWidth="1dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <View
                android:id="@+id/view_accent_bar"
                android:layout_width="5dp"
                android:layout_height="0dp"
                android:background="@drawable/bg_portal_menu_accent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <FrameLayout
                android:id="@+id/icon_container"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginStart="14dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_portal_icon_vacunas"
                app:layout_constraintStart_toEndOf="@id/view_accent_bar"
                app:layout_constraintTop_toTopOf="parent">

                <ImageView
                    android:id="@+id/img_notif_icon"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:contentDescription="@null"
                    tools:src="@drawable/ic_recordatorio" />
            </FrameLayout>

            <View
                android:id="@+id/view_unread_dot"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/bg_portal_unread_dot"
                app:layout_constraintEnd_toEndOf="@id/icon_container"
                app:layout_constraintTop_toTopOf="@id/icon_container" />

            <TextView
                android:id="@+id/tv_notif_titulo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="8dp"
                android:fontFamily="@font/poppins_bold"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                app:layout_constraintEnd_toStartOf="@id/chip_nueva"
                app:layout_constraintStart_toEndOf="@id/icon_container"
                app:layout_constraintTop_toTopOf="@id/icon_container"
                tools:text="Cita programada (PRUEBA)" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_nueva"
                style="@style/Widget.Material3.Chip.Assist"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                android:text="@string/portal_notif_badge_new"
                android:textSize="10sp"
                android:visibility="gone"
                app:chipBackgroundColor="@color/portal_notif_surface"
                app:chipMinHeight="24dp"
                app:chipStrokeColor="@color/portal_notif_accent"
                app:chipStrokeWidth="1dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/icon_container"
                tools:visibility="visible" />

            <TextView
                android:id="@+id/tv_notif_fecha"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginTop="3dp"
                android:fontFamily="@font/poppins_light"
                android:textColor="@color/text_hint"
                android:textSize="11sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/icon_container"
                app:layout_constraintTop_toBottomOf="@id/tv_notif_titulo"
                tools:text="Hace 2 horas" />

            <TextView
                android:id="@+id/tv_notif_mensaje"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="14dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="14dp"
                android:background="@drawable/bg_portal_note_box"
                android:fontFamily="@font/poppins_regular"
                android:padding="10dp"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/view_accent_bar"
                app:layout_constraintTop_toBottomOf="@id/icon_container"
                tools:text="Oreon tiene cita: Consulta de seguimiento el 12/06/2026 a las 16:00" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
